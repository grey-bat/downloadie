<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Takeout Turbo v3.2</title>
    <link rel="icon" type="image/png" href="icon.png">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --bg-dark: #0f172a;
            --card-bg: #1e293b;
            --accent-primary: #a855f7;
            --accent-secondary: #3b82f6;
            --text-main: #f1f5f9;
            --text-dim: #94a3b8;
            --success: #10b981;
            --error: #ef4444;
            --warning: #f59e0b;
        }
        
        body { background-color: var(--bg-dark); color: var(--text-main); font-family: 'Inter', system-ui, sans-serif; margin: 0; padding: 24px; line-height: 1.5; }
        .container { max-width: 1200px; margin: 0 auto; }
        
        header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
        .logo-group { display: flex; align-items: center; gap: 16px; }
        .logo-group img { width: 48px; height: 48px; border-radius: 12px; box-shadow: 0 0 20px rgba(168, 85, 247, 0.3); }
        
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 32px; }
        .stat-card { background: var(--card-bg); padding: 24px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); }
        .stat-label { font-size: 0.75rem; color: var(--text-dim); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
        .stat-value { font-size: 1.75rem; font-weight: 800; font-variant-numeric: tabular-nums; }
        
        .main-layout { display: grid; grid-template-columns: 1fr 350px; gap: 24px; min-height: 500px; }
        .section { background: var(--card-bg); padding: 24px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); }
        .section-title { font-size: 1rem; margin-top: 0; margin-bottom: 24px; color: var(--text-dim); font-weight: 600; display: flex; justify-content: space-between; }
        
        .pipeline-item { background: rgba(15, 23, 42, 0.5); padding: 24px; border-radius: 12px; border-left: 4px solid var(--accent-primary); }
        .pipeline-info { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; }
        .pipeline-name { font-weight: 700; font-size: 1.25rem; color: var(--text-main); }
        .pipeline-status { font-size: 0.75rem; background: var(--accent-primary); color: white; padding: 4px 12px; border-radius: 99px; font-weight: 700; }
        
        .progress-container { margin: 20px 0; }
        .progress-bar-bg { background: rgba(255,255,255,0.05); border-radius: 12px; height: 16px; overflow: hidden; }
        .progress-bar-fill { height: 100%; background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary)); transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1); width: 0%; }
        .progress-details { display: flex; justify-content: space-between; font-size: 0.875rem; margin-top: 12px; color: var(--text-dim); }
        
        .event-log { height: 450px; overflow-y: auto; }
        .log-entry { margin-bottom: 12px; padding: 12px; border-radius: 8px; background: rgba(0,0,0,0.1); border-left: 3px solid transparent; }
        .log-entry.success { border-left-color: var(--success); }
        .log-entry.error { border-left-color: var(--error); }
        .log-entry.info { border-left-color: var(--accent-secondary); }
        .log-time { color: var(--text-dim); font-size: 0.75rem; display: block; margin-bottom: 4px; }
        .log-msg { font-size: 0.85rem; color: #e2e8f0; }
        
        .queue-item { padding: 12px; background: rgba(255,255,255,0.03); border-radius: 8px; margin-bottom: 8px; font-size: 0.85rem; display: flex; justify-content: space-between; align-items: center; }
        .queue-idx { font-weight: bold; color: var(--accent-primary); margin-right: 10px; }
        
        .chart-container { height: 250px; margin-top: 24px; }
        #connection-status { background: rgba(16, 185, 129, 0.1); color: var(--success); border: 1px solid rgba(16, 185, 129, 0.2); padding: 4px 12px; border-radius: 99px; font-size: 0.75rem; font-weight: 700; }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <div class="logo-group">
            </div>
            <div class="text-right">
                <div id="overall-progress-text" class="text-2xl font-mono text-blue-400">0.0 GB / 5.8 TB</div>
                <div class="w-64 h-2 bg-slate-800 rounded-full mt-2 overflow-hidden">
                    <div id="overall-progress-bar" class="h-full bg-blue-500" style="width: 0%"></div>
                </div>
            </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <!-- Download Slot -->
            <div id="dl-card" class="card rounded-xl p-6">
                <div class="flex justify-between items-start mb-4">
                    <h2 class="text-lg font-semibold text-slate-300">Active Download</h2>
                    <span id="dl-phase" class="px-2 py-1 rounded text-xs font-bold bg-slate-700 text-slate-300">IDLE</span>
                </div>
                <div id="dl-active-content">
                    <div id="dl-name" class="text-xl font-bold mb-2">--</div>
                    <div class="flex justify-between text-sm mb-1">
                        <span id="dl-progress-text">0%</span>
                        <span id="dl-gb-text">0.0 / 0.0 GB</span>
                    </div>
                    <div class="w-full h-3 bg-slate-800 rounded-full overflow-hidden mb-4">
                        <div id="dl-progress-bar" class="h-full bg-blue-500 progress-bar-fill" style="width: 0%"></div>
                    </div>
                    <div class="grid grid-cols-2 gap-4 text-center">
                        <div class="bg-slate-800/50 rounded p-2">
                            <div class="text-xs text-slate-400 uppercase">Speed</div>
                            <div id="dl-speed" class="text-lg font-mono font-bold text-blue-400">0 MB/s</div>
                        </div>
                        <div class="bg-slate-800/50 rounded p-2">
                            <div class="text-xs text-slate-400 uppercase">ETA</div>
                            <div id="dl-eta" class="text-lg font-mono font-bold text-blue-400">--</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Extraction Slot -->
            <div id="ex-card" class="card rounded-xl p-6 border-l-4 border-l-emerald-500">
                <div class="flex justify-between items-start mb-4">
                    <h2 class="text-lg font-semibold text-slate-300">Active Unzip</h2>
                    <span id="ex-phase" class="px-2 py-1 rounded text-xs font-bold bg-emerald-900 text-emerald-300">IDLE</span>
                </div>
                <div id="ex-active-content">
                    <div id="ex-name" class="text-xl font-bold mb-2">--</div>
                    <div class="flex justify-between text-sm mb-1">
                        <span id="ex-progress-text">0%</span>
                        <span id="ex-gb-text">0.0 / 0.0 GB</span>
                    </div>
                    <div class="w-full h-3 bg-slate-800 rounded-full overflow-hidden mb-4">
                        <div id="ex-progress-bar" class="h-full bg-emerald-500 progress-bar-fill" style="width: 0%"></div>
                    </div>
                    <div class="grid grid-cols-2 gap-4 text-center">
                        <div class="bg-slate-800/50 rounded p-2">
                            <div class="text-xs text-slate-400 uppercase">Speed</div>
                            <div id="ex-speed" class="text-lg font-mono font-bold text-emerald-400">0 MB/s</div>
                        </div>
                        <div class="bg-slate-800/50 rounded p-2">
                            <div class="text-xs text-slate-400 uppercase">ETA</div>
                            <div id="ex-eta" class="text-lg font-mono font-bold text-emerald-400">--</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Queue Visibility -->
            <div class="md:col-span-1 card rounded-xl p-6">
                <h2 class="text-lg font-semibold mb-4 flex items-center">
                    Upcoming Queue
                    <span id="queue-count" class="ml-2 bg-slate-700 text-xs px-2 py-0.5 rounded-full">0</span>
                </h2>
                <ul id="queue-list" class="space-y-2">
                    <li class="text-slate-500 italic text-sm text-center py-4">Queue is empty</li>
                </ul>
            </div>

            <!-- Activity Log -->
            <div class="md:col-span-2 card rounded-xl p-6">
                <h2 class="text-lg font-semibold mb-4">Pipeline Event Log</h2>
                <div id="log-container" class="space-y-2 h-64 overflow-y-auto pr-2 font-mono text-sm">
                    <div class="text-slate-500 italic">Waiting for events...</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const TOTAL_GOAL_GB = 5800;

        async function updateDashboard() {
            try {
                const response = await fetch('status.json?t=' + Date.now());
                const data = await response.json();

                // Overall Header
                document.getElementById('system-time').innerText = 'Last update: ' + data.time;
                document.getElementById('overall-progress-text').innerText = data.total_gb_processed.toFixed(1) + ' GB / 5.8 TB';
                const overallPct = (data.total_gb_processed / TOTAL_GOAL_GB) * 100;
                document.getElementById('overall-progress-bar').style.width = overallPct.toFixed(2) + '%';

                // Download Card
                document.getElementById('dl-name').innerText = data.dl_name || 'Idle';
                document.getElementById('dl-phase').innerText = data.dl_phase || 'IDLE';
                document.getElementById('dl-progress-text').innerText = (data.dl_pct || 0) + '%';
                document.getElementById('dl-gb-text').innerText = (data.dl_bytes / 1073741824).toFixed(1) + ' / ' + (data.dl_total_bytes / 1073741824).toFixed(1) + ' GB';
                document.getElementById('dl-progress-bar').style.width = (data.dl_pct || 0) + '%';
                document.getElementById('dl-speed').innerText = (data.dl_speed || 0).toFixed(1) + ' MB/s';
                document.getElementById('dl-eta').innerText = data.dl_eta || '--';

                // Extraction Card
                document.getElementById('ex-name').innerText = data.ex_name || 'Idle';
                document.getElementById('ex-phase').innerText = data.ex_phase || 'IDLE';
                document.getElementById('ex-progress-text').innerText = (data.ex_pct || 0) + '%';
                document.getElementById('ex-gb-text').innerText = (data.ex_bytes / 1073741824).toFixed(1) + ' / ' + (data.ex_total_bytes / 1073741824).toFixed(1) + ' GB';
                document.getElementById('ex-progress-bar').style.width = (data.ex_pct || 0) + '%';
                document.getElementById('ex-speed').innerText = (data.ex_speed || 0).toFixed(1) + ' MB/s';
                document.getElementById('ex-eta').innerText = data.ex_eta || '--';

                // Queue
                const queueList = document.getElementById('queue-list');
                const upcoming = data.upcoming_queue || [];
                document.getElementById('queue-count').innerText = upcoming.length;
                if (upcoming.length > 0) {
                    queueList.innerHTML = upcoming.map(name => 
                        `<li class="flex items-center text-sm p-2 bg-slate-800 rounded">
                            <span class="w-2 h-2 rounded-full bg-slate-600 mr-2"></span>
                            ${name}
                        </li>`
                    ).join('');
                } else {
                    queueList.innerHTML = `<li class="text-slate-500 italic text-sm text-center py-4">Queue is empty</li>`;
                }

                // Log
                const logResponse = await fetch('activity.json?t=' + Date.now());
                const logs = await logResponse.json();
                const logContainer = document.getElementById('log-container');
                if (logs.length > 0) {
                    logContainer.innerHTML = logs.map(entry => {
                        let color = 'text-slate-400';
                        if (entry.type === 'success') color = 'text-emerald-400';
                        if (entry.type === 'error') color = 'text-rose-400';
                        return `<div class="${color}">
                            <span class="text-slate-600 mr-2">[${entry.time}]</span>
                            ${entry.msg}
                        </div>`;
                    }).join('');
                    idleView.style.display = 'flex';
                }

            } catch (e) { console.error('Dashboard Sync Error:', e); }
        }

        async function updateLogs() {
            try {
                const res = await fetch('activity.json?t=' + Date.now());
                if (!res.ok) return;
                const logs = await res.json();
                const container = document.getElementById('system-log');
                
                if (!logs || logs.length === 0) {
                    container.innerHTML = '<div style="text-align:center; padding:20px; color:var(--text-dim)">Waiting for logs...</div>';
                    return;
                }

                container.innerHTML = logs.slice(0, 50).map(log => `
                    <div class="log-entry ${log.type}">
                        <span class="log-time">${log.time}</span>
                        <span class="log-msg">${log.msg}</span>
                    </div>
                `).join('');
            } catch (e) { }
        }

        initChart();
        setInterval(updateDashboard, 2000);
        setInterval(updateLogs, 3000);
        updateDashboard();
        updateLogs();
    </script>
</body>
</html>
